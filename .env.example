# ============================================================================
# VARIABLES DE ENTORNO - AbnerFranco.me Backend
# ============================================================================
#
# INSTRUCCIONES:
# 1. Copia este archivo y renombralo a ".env" (en la raiz del proyecto)
# 2. Completa los valores segun tu entorno
# 3. Nunca subas el archivo .env a GitHub

# ============================================================================
# FLASK
# ============================================================================
# Clave secreta para sesiones y seguridad interna de Flask.
# Usa una clave larga y aleatoria.
FLASK_SECRET_KEY=change-this-to-a-long-random-secret

# Entorno de ejecucion: development o production
FLASK_ENV=development


# ============================================================================
# GMAIL SMTP (Formulario de contacto)
# ============================================================================
# Cuenta Gmail que enviara los correos desde /api/send-message
MAIL_USERNAME=tu-correo@gmail.com

# Contrasena de aplicacion de Google (16 caracteres), NO tu contrasena normal
MAIL_PASSWORD=tu-app-password-de-16-caracteres


# ============================================================================
# DOMINIO / URL BASE (Opcional)
# ============================================================================
# URL local por defecto
DOMAIN=http://localhost:5000

# En produccion puedes usar, por ejemplo:
# DOMAIN=https://abnerfranco.me
