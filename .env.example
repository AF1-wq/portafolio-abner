# ============================================================================
# CONFIGURACIÓN DE VARIABLES DE ENTORNO
# ============================================================================
# Copiar este archivo como .env y completar con tus credenciales reales

# ============================================================================
# CONFIGURACIÓN DE FLASK
# ============================================================================
FLASK_ENV=production
FLASK_SECRET_KEY=tu-clave-secreta-aleatoria-muy-larga-y-segura

# ============================================================================
# CONFIGURACIÓN DE GMAIL PARA ENVÍO DE CORREOS
# ============================================================================
# IMPORTANTE: Necesitas configurar una "Contraseña de aplicación" en Gmail
#
# Pasos para obtener una contraseña de aplicación de Gmail:
# 1. Ir a https://myaccount.google.com/security
# 2. Activar la verificación en dos pasos (si no está activa)
# 3. Buscar "Contraseñas de aplicaciones"
# 4. Generar una nueva contraseña de aplicación para "Correo"
# 5. Copiar la contraseña generada (16 caracteres sin espacios)
#
MAIL_USERNAME=tu-email@gmail.com
MAIL_PASSWORD=xxxx-xxxx-xxxx-xxxx

# ============================================================================
# NOTAS DE SEGURIDAD
# ============================================================================
# ⚠️  NUNCA subas el archivo .env a GitHub
# ⚠️  El archivo .env está en .gitignore para evitar commits accidentales
# ⚠️  Usa contraseñas de aplicación de Gmail, no tu contraseña personal
# ⚠️  Cambia FLASK_SECRET_KEY a algo aleatorio y único
