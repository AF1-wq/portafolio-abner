# ============================================================================
# .gitignore - Archivos y carpetas a NO subir a GitHub
# ============================================================================

# ⚠️ VARIABLES DE ENTORNO (¡MÁS IMPORTANTE!)
.env
.env.local
.env.*.local

# ============================================================================
# PYTHON
# ============================================================================

# Bytecode compilado
__pycache__/
*.py[cod]
*$py.class

# C extensions
*.so

# Distribution / packaging
.Python
build/
develop-eggs/
dist/
downloads/
eggs/
.eggs/
lib/
lib64/
parts/
sdist/
var/
wheels/
pip-wheel-metadata/
share/python-wheels/
*.egg-info/
.installed.cfg
*.egg
MANIFEST

# pip
*.pip

# Entornos virtuales
venv/
ENV/
env/
.venv/
env.bak/
venv.bak/

# Archivos de pruebas
.pytest_cache/
.coverage
htmlcov/

# ============================================================================
# NODE.JS
# ============================================================================
node_modules/
npm-debug.log
yarn-error.log
.npm
package-lock.json

# ============================================================================
# IDE
# ============================================================================
.vscode/
.idea/
*.swp
*.swo
*~
.DS_Store

# ============================================================================
# BASE DE DATOS
# ============================================================================
*.db
*.sqlite
*.sqlite3
database/

# ============================================================================
# LOGS
# ============================================================================
*.log
logs/

# ============================================================================
# ARCHIVOS DEL SISTEMA
# ============================================================================
Thumbs.db
.env.bak
*.tmp
